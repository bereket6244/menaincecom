# --- Server ---
PORT=4000
# REQUIRED: long random string (e.g. `openssl rand -hex 32`). Placeholder
# values are rejected — the server then uses a random per-boot secret and all
# logins reset on every restart.
JWT_SECRET=change-me-to-a-long-random-string
# Comma-separated origins allowed to call the API cross-origin.
# Leave empty in production when this server also serves the client.
CORS_ORIGIN=http://localhost:5173

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mena_inc
# Set true locally when you want the app to fail instead of using dev-data.json.
DB_REQUIRE_MYSQL=false
USE_LOCAL_STORE=false

# --- Seed admin account (created on first boot if missing) ---
# The seed is SKIPPED unless ADMIN_PASSWORD is set and at least 12 characters
# (known defaults like "change-me" are rejected as a backdoor risk).
ADMIN_IDENTIFIER=superadmin@menaincet.com
ADMIN_PASSWORD=replace-with-a-unique-14-plus-character-password
ADMIN_NAME=Mena Superadmin

# --- Telegram bot (order delivery to the team) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WhatsApp Business Cloud API (order delivery to the team) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEAM_NUMBER=2519XXXXXXXX

# --- Web Push (admin notifications). Generate with: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@menainc.com
